<?xml version="1.0" encoding="UTF-8"?>
<!-- Merged into cargo-bundle Info.plist when present.
     CFBundleIconName enables Liquid Glass Assets.car on macOS 26+.
     CFBundleIconFile covers classic .icns on older macOS. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleIconFile</key>
  <string>snack</string>
  <key>CFBundleIconName</key>
  <string>snack</string>
</dict>
</plist>
